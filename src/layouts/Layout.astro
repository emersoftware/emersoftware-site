---
interface Props {
  title: string;
  description: string;
}

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import '@fontsource-variable/inter';
import '@fontsource-variable/eb-garamond';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Emerson Salazar Rubilar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <meta name="astro-view-transitions" />
  </head>
  <div class="fixed -z-10 h-full w-full">
    <div class="h- bg absolute inset-0 -z-10 w-full items-center px-5 py-24"></div>
    <div id="stars-container" class="stars-container"></div>
  </div>
  <body class="relative">
    <Navbar />
    <main class="pt-20 md:pt-24">
      <slot />
    </main>
    <Footer />
  </body>

  <style is:global>
    :root {
      color-scheme: light dark;
    }

    html {
      font-family: system-ui, sans-serif;
      scroll-behavior: smooth;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      overscroll-behavior: none;
      font-family: 'Inter', sans-serif;
    }

    .title {
      font-family: 'EB Garamond', serif;
      letter-spacing: -3px;
    }

    /* Stars Background */
    .stars-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -5;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .star {
      position: absolute;
      background-color: #fff;
      border-radius: 50%;
      opacity: 0;
      animation: twinkle var(--duration, 4s) ease-in-out infinite;
      animation-delay: var(--delay, 0s);
    }

    @keyframes twinkle {
      0%,
      100% {
        opacity: 0;
      }
      50% {
        opacity: var(--opacity, 1);
      }
    }

    @media (prefers-color-scheme: dark) {
      .stars-container {
        opacity: 1;
      }
    }

    /* Animation classes */
    .fade-in {
      animation: fadeIn 0.8s ease-in-out forwards;
      opacity: 0;
    }

    .fade-in-delay-100 {
      animation: fadeIn 0.8s ease-in-out 0.1s forwards;
      opacity: 0;
    }

    .fade-in-delay-200 {
      animation: fadeIn 0.8s ease-in-out 0.2s forwards;
      opacity: 0;
    }

    .fade-in-delay-300 {
      animation: fadeIn 0.8s ease-in-out 0.3s forwards;
      opacity: 0;
    }

    .fade-in-delay-400 {
      animation: fadeIn 0.8s ease-in-out 0.4s forwards;
      opacity: 0;
    }

    .fade-in-delay-500 {
      animation: fadeIn 0.8s ease-in-out 0.5s forwards;
      opacity: 0;
    }

    .slide-up {
      animation: slideUp 0.8s ease-in-out forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .slide-up-delay-100 {
      animation: slideUp 0.8s ease-in-out 0.1s forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .slide-up-delay-200 {
      animation: slideUp 0.8s ease-in-out 0.2s forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .slide-up-delay-300 {
      animation: slideUp 0.8s ease-in-out 0.3s forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .slide-up-delay-400 {
      animation: slideUp 0.8s ease-in-out 0.4s forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .slide-up-delay-500 {
      animation: slideUp 0.8s ease-in-out 0.5s forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduce-motion: reduce) {
      .fade-in,
      .fade-in-delay-100,
      .fade-in-delay-200,
      .fade-in-delay-300,
      .fade-in-delay-400,
      .fade-in-delay-500,
      .slide-up,
      .slide-up-delay-100,
      .slide-up-delay-200,
      .slide-up-delay-300,
      .slide-up-delay-400,
      .slide-up-delay-500 {
        animation: none;
        opacity: 1;
        transform: none;
      }

      html {
        scroll-behavior: auto;
      }
    }

    @media (prefers-color-scheme: light) {
      .bg {
        background: radial-gradient(86.36% 112.8% at 50% 0%, #fff 68.5%, #c1ffcf 100%);
      }
    }

    @media (prefers-color-scheme: dark) {
      .bg {
        background: radial-gradient(86.36% 112.8% at 50% 0%, #000 68.5%, #0400b4 100%);
      }
    }
  </style>

  <script>
    // Create stars and add parallax effect
    document.addEventListener('DOMContentLoaded', () => {
      const starsContainer = document.getElementById('stars-container');
      const numStars = 200;
      const starSizes = [1, 1.5, 2];
      const parallaxLayers = [0.2, 0.5, 0.8]; // Different parallax speeds for different star sizes

      // Create stars
      for (let i = 0; i < numStars; i++) {
        const star = document.createElement('div');
        star.className = 'star';

        // Randomly select star properties
        const sizeIndex = Math.floor(Math.random() * starSizes.length);
        const size = starSizes[sizeIndex];
        const opacity = 0.5 + Math.random() * 0.5;
        const layer = parallaxLayers[sizeIndex];

        // Set star position and style
        star.style.setProperty('--opacity', opacity.toString());
        star.style.setProperty('--duration', 3 + Math.random() * 5 + 's');
        star.style.setProperty('--delay', Math.random() * 5 + 's');
        star.style.width = size + 'px';
        star.style.height = size + 'px';
        star.style.left = Math.random() * 100 + '%';
        star.style.top = Math.random() * 100 + '%';
        (star as HTMLElement).dataset.layer = layer.toString();

        starsContainer?.appendChild(star);
      }

      // Add parallax effect on scroll
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const stars = document.querySelectorAll('.star');

        stars.forEach((star) => {
          const layer = parseFloat((star as HTMLElement).dataset.layer || '0');
          const yOffset = scrollY * layer;
          (star as HTMLElement).style.transform = `translateY(${yOffset}px)`;
        });
      });
    });
  </script>


</html>
