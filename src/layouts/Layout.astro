---
interface Props {
  title: string;
  description: string;
  lang?: string;
  bare?: boolean;
}

import Footer from '../components/Footer.astro';
import { supportedLocales, defaultLocale, isSupportedLocale } from '../i18n/config';

import '../styles/tailwind.css';
import '@fontsource-variable/inter';
import '@fontsource/jacques-francois/latin.css';

const { title, description, lang = 'es', bare = false } = Astro.props;
const siteUrl = Astro.url.origin;
const currentPath = Astro.url.pathname;

const normalizedLang = isSupportedLocale(lang) ? lang : defaultLocale;
const stripEnPrefix = (path: string) => path.replace(/^\/en(?=\/|$)/, '') || '/';
const ensureEnPrefix = (path: string) => (/^\/en(?=\/|$)/.test(path) ? path : `/en${path}`);

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Emerson Salazar Rubilar',
  jobTitle: normalizedLang === 'en' ? 'Software Engineer' : 'Ingeniero de Software',
  url: siteUrl,
  email: 'hola@emersoftware.cl',
  sameAs: [
    'https://github.com/emersoftware',
    'https://www.linkedin.com/in/emerson-salazar-rubilar',
  ],
  homeLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Concepción',
      addressCountry: 'CL',
    },
  },
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: siteUrl,
  name: 'Emersoftware',
  inLanguage: normalizedLang === 'en' ? 'en' : 'es-CL',
  publisher: {
    '@type': 'Person',
    name: 'Emerson Salazar Rubilar',
    url: siteUrl,
  },
};
---

<!doctype html>
<html lang={normalizedLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <!-- viewport-fit=cover: la página pinta hasta los bordes físicos (notch y
         home indicator) y env(safe-area-inset-*) pasa a tener valor en iOS. -->
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Emerson Salazar Rubilar" />
    <meta http-equiv="content-language" content={normalizedLang === 'en' ? 'en' : 'es-CL'} />
    <!-- En el home (bare) la UI de Safari debe teñirse oscura como el hero. -->
    <meta name="theme-color" content={bare ? '#000000' : '#ffffff'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Emersoftware" />
    <meta property="og:locale" content={normalizedLang === 'en' ? 'en_US' : 'es_CL'} />
    <meta property="og:image" content="/social.jpg" />
    {
      supportedLocales.map((loc) => {
        const href = loc === 'es' ? stripEnPrefix(currentPath) : ensureEnPrefix(currentPath);
        return <link rel="alternate" hreflang={loc} href={new URL(href, siteUrl).href} />;
      })
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(stripEnPrefix(currentPath), siteUrl).href}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/social.jpg" />
    <title>{title}</title>
    <meta name="astro-view-transitions" />
    <script type="application/ld+json" set:html={JSON.stringify([websiteLd, personLd])} />
  </head>
  <body class={bare ? 'bg-black is-bare' : 'bg-white'}>
    <div class="fixed h-full w-full">
      <div class="bg absolute inset-0 w-full items-center px-5 py-24"></div>
    </div>
    <slot />
    {!bare && <Footer lang={normalizedLang} currentPath={currentPath} />}

    <style is:global>
      :root {
        color-scheme: light;
      }

      html {
        font-family: 'Jacques Francois', system-ui, serif;
        scroll-behavior: smooth;
      }

      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
        font-family: 'Jacques Francois', serif;
        color: #000000;
      }

      /* En páginas "hoja" (bare), quitamos el flex del body para que
         position: sticky del hero y de la nav funcionen con normalidad. */
      body.is-bare {
        display: block;
      }

      /* Con viewport-fit=cover, las páginas normales no deben quedar bajo la
         status bar. El home (bare) sí pinta edge-to-edge: su hero lo cubre. */
      body:not(.is-bare) {
        padding-top: env(safe-area-inset-top, 0px);
      }

      /* Botones, inputs y elementos interactivos usan la sans (Inter) */
      button,
      input,
      textarea,
      select,
      a.btn,
      .contact-btn,
      .hero-pill {
        font-family: 'Inter', sans-serif;
      }

      /* Jacques Francois solo tiene peso 400: forzamos normal en todo el cuerpo
         para evitar faux-bold. Los botones/inputs (Inter) conservan sus pesos. */
      body,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      p,
      span,
      a,
      li,
      strong,
      b,
      .title {
        font-family: 'Jacques Francois', serif;
        font-weight: 400 !important;
      }

      /* Excepciones: elementos interactivos siguen en Inter con sus pesos */
      button,
      input,
      textarea,
      select,
      .contact-btn,
      .hero-pill {
        font-family: 'Inter', sans-serif;
        font-weight: inherit;
      }

      .title {
        font-family: 'Jacques Francois', serif;
        letter-spacing: -0.04em;
      }

      /* Animation classes */
      .fade-in {
        animation: fadeIn 0.8s ease-in-out forwards;
        opacity: 0;
      }

      .fade-in-delay-100 {
        animation: fadeIn 0.8s ease-in-out 0.1s forwards;
        opacity: 0;
      }

      .fade-in-delay-200 {
        animation: fadeIn 0.8s ease-in-out 0.2s forwards;
        opacity: 0;
      }

      .fade-in-delay-300 {
        animation: fadeIn 0.8s ease-in-out 0.3s forwards;
        opacity: 0;
      }

      .fade-in-delay-400 {
        animation: fadeIn 0.8s ease-in-out 0.4s forwards;
        opacity: 0;
      }

      .fade-in-delay-500 {
        animation: fadeIn 0.8s ease-in-out 0.5s forwards;
        opacity: 0;
      }

      .slide-up {
        animation: slideUp 0.8s ease-in-out forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      .slide-up-delay-100 {
        animation: slideUp 0.8s ease-in-out 0.1s forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      .slide-up-delay-200 {
        animation: slideUp 0.8s ease-in-out 0.2s forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      .slide-up-delay-300 {
        animation: slideUp 0.8s ease-in-out 0.3s forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      .slide-up-delay-400 {
        animation: slideUp 0.8s ease-in-out 0.4s forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      .slide-up-delay-500 {
        animation: slideUp 0.8s ease-in-out 0.5s forwards;
        opacity: 0;
        transform: translateY(20px);
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* El desvanecimiento del hero anima solo opacity (composición en GPU).
         El blur de las pills queda fijo (backdrop-blur-md de Tailwind): animar
         el radio del backdrop-filter re-rasteriza el fondo por frame en WebKit.
         La opacidad va en la pill misma, no en un ancestro: opacity sobre un
         ancestro de backdrop-filter crea un backdrop root y rompe el muestreo. */
      [data-hero-overlay] {
        --hero-visibility: 1;
      }

      [data-hero-fade] {
        opacity: var(--hero-visibility);
      }

      [data-hero-overlay] .hero-pill {
        opacity: var(--hero-visibility);
      }

      [data-hero-overlay] .hero-pill > span {
        font-family: 'Inter', sans-serif !important;
      }

      /* Fallback for browsers that don't support lvh/svh units */
      @supports not (height: 100lvh) {
        .hero-section {
          height: 100vh;
        }

        [data-hero-overlay] {
          height: 100%;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .fade-in,
        .fade-in-delay-100,
        .fade-in-delay-200,
        .fade-in-delay-300,
        .fade-in-delay-400,
        .fade-in-delay-500,
        .slide-up,
        .slide-up-delay-100,
        .slide-up-delay-200,
        .slide-up-delay-300,
        .slide-up-delay-400,
        .slide-up-delay-500 {
          animation: none;
          opacity: 1;
          transform: none;
        }

        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </body>
</html>
