---
import Layout from '../../layouts/Layout.astro';
import GitHubIcon from '../../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../../components/icons/LinkedInIcon.astro';
import Mail from '../../components/icons/MailIcon.astro';
import Copy from '../../components/icons/CopyIcon.astro';
import CopyCheck from '../../components/icons/CopyCheckIcon.astro';
import GitHubLatestCommit from '../../components/GitHubLatestCommit.astro';
import Experience from '../../components/Experience.astro';
import Projects from '../../components/Projects.astro';
import Contact from '../../components/Contact.astro';
import { getDictionary } from '../../i18n/dictionaries';

const lang = 'en';
const t = getDictionary(lang);
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang}>
  <!-- Hero Section - Full Screen -->
  <section
    class="hero-section relative -mt-20 flex h-dvh flex-col justify-start pt-32 md:-mt-24 md:justify-end md:pt-0"
    id={t.sectionIds.home}
    data-section={t.sectionIds.home}
  >
    <!-- Background Image - Mobile -->
    <div class="absolute inset-0 z-0 md:hidden">
      <img
        src="/hero-bg-mobile.jpeg"
        alt=""
        class="h-full w-full object-cover object-bottom"
        loading="eager"
      />
    </div>
    <!-- Background Image - Desktop -->
    <div class="absolute inset-0 z-0 hidden md:block">
      <img
        src="/hero-bg.jpeg"
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
      />
    </div>

    <!-- Content - Text -->
    <div class="relative z-10 px-6 md:mb-24 md:px-12 lg:mb-32 lg:px-16">
      <div class="max-w-2xl">
        <!-- GitHub Commit - Desktop: above the name -->
        <GitHubLatestCommit lang={lang} class="mb-4 hidden md:flex" />

        <h1 class="title fade-in text-4xl text-white md:text-5xl lg:text-7xl">
          {t.hero.name}
        </h1>

        <p class="fade-in-delay-100 mt-3 text-lg text-white/80 md:text-xl lg:text-2xl">
          {t.hero.role}
        </p>

        <p class="fade-in-delay-200 mt-6 max-w-lg text-base text-white/70 md:text-lg">
          {t.hero.about}
        </p>

        <!-- GitHub Commit - Mobile: below about -->
        <GitHubLatestCommit lang={lang} class="mt-4 flex md:hidden" />

        <!-- Botones desktop -->
        <nav class="fade-in-delay-300 mt-8 hidden flex-wrap gap-3 md:flex">
          <a
            href="https://github.com/emersoftware"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md transition-all hover:bg-white/20"
          >
            <GitHubIcon class="size-5" />
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/emerson-salazar-rubilar"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md transition-all hover:bg-white/20"
          >
            <LinkedInIcon class="size-5" />
            LinkedIn
          </a>
          <button
            id="emailButtonDesktop"
            class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md transition-all hover:bg-white/20"
          >
            <Mail class="size-5" />
            {t.hero.email}
            <Copy id="copyEmailDesktop" class="size-5" />
            <CopyCheck id="copyEmailCheckDesktop" class="hidden size-5" />
          </button>
        </nav>
      </div>
    </div>

    <!-- Botones mobile - Fixed bottom -->
    <nav class="fade-in-delay-300 absolute bottom-8 left-0 right-0 z-10 flex justify-center gap-2 px-4 md:hidden">
      <a
        href="https://github.com/emersoftware"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-pill flex items-center gap-1.5 rounded-full border border-white/20 bg-black/40 px-3 py-2.5 text-sm text-white backdrop-blur-md transition-all hover:bg-black/50"
      >
        <GitHubIcon class="size-4" />
        github
      </a>
      <a
        href="https://www.linkedin.com/in/emerson-salazar-rubilar"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-pill flex items-center gap-1.5 rounded-full border border-white/20 bg-black/40 px-3 py-2.5 text-sm text-white backdrop-blur-md transition-all hover:bg-black/50"
      >
        <LinkedInIcon class="size-4" />
        linkedin
      </a>
      <button
        id="emailButtonMobile"
        class="hero-pill flex items-center gap-1.5 rounded-full border border-white/20 bg-black/40 px-3 py-2.5 text-sm text-white backdrop-blur-md transition-all hover:bg-black/50"
      >
        <Mail class="size-4" />
        copy email
        <CopyCheck id="copyEmailCheckMobile" class="hidden size-4" />
      </button>
    </nav>

  </section>

  <main class="mx-4 md:mx-auto md:w-4/5 lg:w-3/4 xl:w-2/3">

    <section class="slide-up" id={t.sectionIds.experience} data-section={t.sectionIds.experience}>
      <h2 class="title mt-16 text-4xl text-black md:mt-20 lg:mt-24 lg:text-6xl">{t.sections.experience}</h2>
      <Experience lang={lang} />
    </section>

    <!-- Banner between sections -->
    <div class="my-16">
      <img
        src="/banner.jpeg"
        alt=""
        class="w-full h-auto object-cover"
        loading="lazy"
      />
    </div>

    <section class="slide-up-delay-100" id={t.sectionIds.projects} data-section={t.sectionIds.projects}>
      <h2 class="title text-4xl text-black lg:text-6xl">{t.sections.projects}</h2>
      <Projects lang={lang} />
    </section>

    <section
      class="slide-up-delay-200"
      id={t.sectionIds.contact}
      data-section={t.sectionIds.contact}
    >
      <h2 class="title mt-16 text-4xl text-black md:mt-20 lg:mt-24 lg:text-6xl">{t.sections.contact}</h2>
      <Contact lang={lang} />
    </section>
  </main>
</Layout>

<script define:vars={{ email: t.hero.email }}>
  function setupEmailButton(buttonId, copyId, checkId) {
    const button = document.querySelector(buttonId);
    const copyIcon = document.querySelector(copyId);
    const checkIcon = document.querySelector(checkId);

    if (button && copyIcon && checkIcon) {
      button.addEventListener('click', () => {
        navigator.clipboard.writeText(email).then(() => {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 2000);
        });
      });
    }
  }

  setupEmailButton('#emailButtonDesktop', '#copyEmailDesktop', '#copyEmailCheckDesktop');
  setupEmailButton('#emailButtonMobile', '#copyEmailMobile', '#copyEmailCheckMobile');
</script>
