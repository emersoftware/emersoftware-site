---
import Layout from '../../layouts/Layout.astro';
import GitHubIcon from '../../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../../components/icons/LinkedInIcon.astro';
import Mail from '../../components/icons/MailIcon.astro';
import Copy from '../../components/icons/CopyIcon.astro';
import CopyCheck from '../../components/icons/CopyCheckIcon.astro';
import GitHubLatestCommit from '../../components/GitHubLatestCommit.astro';
import Experience from '../../components/Experience.astro';
import Projects from '../../components/Projects.astro';
import Contact from '../../components/Contact.astro';
import BlogList from '../../components/BlogList.astro';
import Navbar from '../../components/Navbar.astro';
import SectionNav from '../../components/SectionNav.astro';
import Footer from '../../components/Footer.astro';
import { getDictionary } from '../../i18n/dictionaries';

const lang = 'en';
const t = getDictionary(lang);
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang} bare>
  <!-- The hero remains fixed while the sheet covers it. -->
  <section class="hero-section fixed inset-0 z-0 h-dvh overflow-hidden">
    <div class="absolute inset-0">
      <picture>
        <source media="(min-width: 768px)" srcset="/hero-bg.jpeg" />
        <img
          src="/hero-bg-mobile.jpeg"
          alt=""
          class="h-full w-full object-cover object-bottom md:object-center"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>

    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black to-transparent lg:hidden"
      aria-hidden="true"
    >
    </div>

    <div data-hero-overlay class="relative h-full">
      <Navbar lang={lang} />

      <div class="relative z-10 flex h-full items-end">
        <div class="w-full min-w-0 px-6 pb-36 md:px-12 md:pb-48 lg:px-16 lg:pb-32">
          <div class="w-full max-w-2xl min-w-0">
            <GitHubLatestCommit lang={lang} class="mb-4 flex w-full" />

            <div class="fade-in">
              <h1 data-hero-fade class="title text-lg text-white md:text-2xl lg:text-4xl">
                {t.hero.name}
              </h1>
            </div>

            <div class="fade-in-delay-100 mt-3">
              <p data-hero-fade class="text-lg text-white/80 md:text-xl lg:text-2xl">
                {t.hero.role}
              </p>
            </div>

            <div class="fade-in-delay-200 mt-6">
              <p data-hero-fade class="max-w-lg text-base break-words text-white/70 md:text-lg">
                {t.hero.about}
              </p>
            </div>

            <nav class="mt-4 flex min-w-0 justify-center gap-1 md:hidden">
              <a
                href="https://github.com/emersoftware"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <GitHubIcon class="size-4" />
                <span>github</span>
              </a>
              <a
                href="https://www.linkedin.com/in/emerson-salazar-rubilar"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <LinkedInIcon class="size-4" />
                <span>linkedin</span>
              </a>
              <button
                id="emailButtonMobile"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <Mail class="size-4" />
                <span>email</span>
                <Copy id="copyEmailMobile" class="size-4" />
                <CopyCheck id="copyEmailCheckMobile" class="hidden size-4" />
              </button>
            </nav>

            <nav class="mt-8 hidden flex-wrap gap-3 md:flex">
              <a
                href="https://github.com/emersoftware"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md hover:bg-white/20"
              >
                <GitHubIcon class="size-5" />
                <span>GitHub</span>
              </a>
              <a
                href="https://www.linkedin.com/in/emerson-salazar-rubilar"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md hover:bg-white/20"
              >
                <LinkedInIcon class="size-5" />
                <span>LinkedIn</span>
              </a>
              <button
                id="emailButtonDesktop"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-base text-white backdrop-blur-md hover:bg-white/20"
              >
                <Mail class="size-5" />
                <span>{t.hero.email}</span>
                <Copy id="copyEmailDesktop" class="size-5" />
                <CopyCheck id="copyEmailCheckDesktop" class="hidden size-5" />
              </button>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- This track supplies the approach distance and the content travel to the document. -->
  <!-- svh (not dvh): the height must not change when the Safari toolbar collapses mid-scroll. -->
  <div data-sheet-track class="h-[200svh]" aria-hidden="true"></div>

  <!-- Probe to measure 100lvh from JS (window.innerHeight varies with the Safari toolbar). -->
  <div data-viewport-probe class="invisible fixed top-0 left-0 h-lvh w-px" aria-hidden="true"></div>

  <!-- The fixed viewport clips the sheet at its resting position. -->
  <div
    data-sheet-viewport
    class="sheet-viewport pointer-events-none fixed right-0 bottom-0 left-0 z-20 overflow-hidden"
  >
    <div class="mx-auto h-full w-full max-w-4xl px-3 md:max-w-5xl md:px-6">
      <div
        data-sheet-panel
        class="pointer-events-auto flex h-full flex-col bg-white shadow-2xl will-change-transform"
      >
        <SectionNav lang={lang} />

        <div data-sheet-body-viewport class="min-h-0 flex-1 overflow-clip">
          <div data-sheet-body class="will-change-transform">
            <div class="px-6 py-16 md:px-12 md:py-20">
              <section id={t.sectionIds.experience} data-section={t.sectionIds.experience}>
                <Experience lang={lang} />
              </section>

              <section
                id={t.sectionIds.projects}
                data-section={t.sectionIds.projects}
                class="mt-20 md:mt-28"
              >
                <Projects lang={lang} />
              </section>

              <section id="blog" data-section="blog" class="mt-20 md:mt-28">
                <BlogList lang={lang} />
              </section>

              <section
                id={t.sectionIds.contact}
                data-section={t.sectionIds.contact}
                class="mt-20 md:mt-28"
              >
                <Contact lang={lang} />
              </section>
            </div>

            <Footer lang={lang} currentPath={Astro.url.pathname} />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(:root) {
    --sheet-top: 0.75rem;
  }

  @media (min-width: 48rem) {
    :global(:root) {
      --sheet-top: 1.5rem;
    }
  }

  @media (min-width: 64rem) {
    :global(:root) {
      --sheet-top: 4.5rem;
    }
  }

  .sheet-viewport {
    top: var(--sheet-top);
  }

  /* lvh: the panel rests below the largest possible viewport. That way no white
     edge ever peeks above the Safari toolbar, and the distance stays constant
     whether the toolbar collapses or expands. */
  [data-sheet-panel] {
    transform: translate3d(0, calc(100lvh - var(--sheet-top)), 0);
  }

  @supports not (height: 100lvh) {
    [data-sheet-panel] {
      transform: translate3d(0, calc(100vh - var(--sheet-top)), 0);
    }
  }
</style>

<script define:vars={{ email: t.hero.email }}>
  function setupEmailButton(buttonId, copyId, checkId) {
    const button = document.querySelector(buttonId);
    const copyIcon = document.querySelector(copyId);
    const checkIcon = document.querySelector(checkId);

    if (button && copyIcon && checkIcon) {
      button.addEventListener('click', () => {
        navigator.clipboard.writeText(email).then(() => {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 2000);
        });
      });
    }
  }

  setupEmailButton('#emailButtonDesktop', '#copyEmailDesktop', '#copyEmailCheckDesktop');
  setupEmailButton('#emailButtonMobile', '#copyEmailMobile', '#copyEmailCheckMobile');
</script>

<script>
  import '../../scripts/home-scroll';
</script>
