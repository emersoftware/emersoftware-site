---
import Layout from '../layouts/Layout.astro';
import ComputerImg from '../components/icons/ComputerImg.astro';
import PillAnchor from '../components/PillAnchor.astro';
import PillButton from '../components/PillButton.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import Mail from '../components/icons/MailIcon.astro';
import Copy from '../components/icons/CopyIcon.astro';
import CopyCheck from '../components/icons/CopyCheckIcon.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import { getDictionary } from '../i18n/dictionaries';
import { defaultLocale } from '../i18n/config';

const lang = defaultLocale; // pathless default locale at root
const t = getDictionary(lang);
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang}>
  <main class="mx-4 md:mx-auto md:w-3/5 lg:w-1/2">
    <section
      class="flex flex-col items-center justify-center"
      id={t.sectionIds.home}
      data-section={t.sectionIds.home}
    >
      <ComputerImg class="fade-in mx-auto h-auto w-1/2 text-forest lg:w-1/3 dark:text-white" />

      <h2 class="title fade-in-delay-100 mt-8 text-center text-6xl md:mt-10 lg:text-8xl">
        {t.hero.brand}
      </h2>

      <h1
        class="fade-in-delay-200 mr-4 mt-4 flex w-full flex-col justify-center space-x-2 text-center sm:mt-10 md:mt-12 md:flex-row lg:mt-16"
      >
        <p class="whitespace-nowrap text-2xl lg:text-[36px]">{t.hero.name}</p>
        <p class="hidden text-2xl md:inline-block lg:text-[36px]">✹</p>
        <p class="whitespace-nowrap text-xl md:text-2xl lg:text-[36px]">{t.hero.role}</p>
      </h1>

      <p class="text-md fade-in-delay-300 mt-4 text-balance text-center md:mt-8 lg:text-2xl">
        {t.hero.about}
      </p>

      <nav
        class="fade-in-delay-400 mt-4 flex w-fit flex-wrap justify-center gap-x-2 gap-y-2 md:mt-8 md:flex-nowrap md:gap-x-3 lg:gap-x-6"
      >
        <PillAnchor href="https://github.com/emersoftware">
          <GitHubIcon class="size-4 lg:size-6" />
          GitHub
        </PillAnchor>
        <PillAnchor href="https://www.linkedin.com/in/emerson-salazar-rubilar">
          <LinkedInIcon class="size-4 lg:size-6" />
          LinkedIn
        </PillAnchor>
        <PillButton id="emailButton" class="">
          <Mail class="size-6 lg:size-8" />
          {t.hero.email}
          <Copy id="copyEmail" class="size-6 lg:size-8" />
          <CopyCheck id="copyEmailCheck" class="hidden size-6 lg:size-8" />
        </PillButton>
      </nav>
    </section>

    <section class="slide-up" id={t.sectionIds.experience} data-section={t.sectionIds.experience}>
      <h2 class="title mt-16 text-4xl md:mt-20 lg:mt-24 lg:text-6xl">{t.sections.experience}</h2>
      <Experience lang={lang} />
    </section>

    <section
      class="slide-up-delay-200"
      id={t.sectionIds.contact}
      data-section={t.sectionIds.contact}
    >
      <h2 class="title mt-16 text-4xl md:mt-20 lg:mt-24 lg:text-6xl">{t.sections.contact}</h2>
      <Contact lang={lang} />
    </section>
  </main>
</Layout>

<script define:vars={{ email: t.hero.email }}>
  const button = document.querySelector('#emailButton');
  const copyEmail = document.querySelector('#copyEmail');
  const copyEmailCheck = document.querySelector('#copyEmailCheck');

  button.addEventListener('click', () => {
    navigator.clipboard.writeText(email).then(() => {
      copyEmail.classList.add('hidden');
      copyEmailCheck.classList.remove('hidden');
      setTimeout(() => {
        copyEmail.classList.remove('hidden');
        copyEmailCheck.classList.add('hidden');
      }, 2000);
    });
  });
</script>
