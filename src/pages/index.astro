---
import Layout from '../layouts/Layout.astro';
import ComputerImg from '../components/icons/ComputerImg.astro';
import PillAnchor from '../components/PillAnchor.astro';
import PillButton from '../components/PillButton.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import Mail from '../components/icons/MailIcon.astro';
import Copy from '../components/icons/CopyIcon.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Emersoftware" description='Emerson Salazar Rubilar (emersoftware) Desarrollador Web Fullstack de Concepción, Chile. Haz tu proyecto con este programador con tecnologías como JavaScript, NextJS, ReactJS, Astro o Python. Desarrolla landing pages, ecommerce o aplicaciones basadas en inteligencia artificial.'>
	<main>
		<section
			class="w-full mx-2 md:mx-auto md:w-3/5"
		>
			<ComputerImg class="mx-auto w-1/2 h-auto text-forest dark:text-white mt-16 md:mt-20" />
			
			<h1 class="text-6xl text-center title mt-8">emersoftware</h1>
			<div class="text-xl md:text-2xl flex flex-row justify-between space-x-8 mx-auto mt-8">
				<p>Emerson Salazar</p>
				<p>Desarrollador Web</p>
			</div>
			<p class="mx-auto text-pretty">
				Me gusta crear cosas con software y espero que pronto me paguen por ello. Casi Ingeniero Civil Informático.
			</p>

			<nav class="flex flex-wrap md:flex-nowrap gap-1 mt-4 md:mt-8 justify-center">
				<PillAnchor href="https://github.com/emersoftware">
					<GitHubIcon class="size-4" />
					GitHub
				</PillAnchor>
				<PillAnchor href="https://www.linkedin.com/in/emerson-salazar-rubilar-149468220/">
					<LinkedInIcon class="size-4" />
					LinkedIn
				</PillAnchor>
				<PillButton id="emailButton" >
					<Mail class="size-2" />
					e.benjaminsalazarrubilar@gmail.com
					<Copy class="size-2" />
				</PillButton>
			</nav>
		</section>

		<section
			class="w-full mx-2 md:mx-auto md:w-1/2"
		>
			<h2 class="text-4xl title mt-8">Experiencia</h2>
			<Experience />
		</section>


		<section
			class="w-full mx-auto md:w-1/2"
		>
			<h2 class="text-4xl title mt-8">Contacto</h2>
			<Contact />
		</section>

	</main>
</Layout>

<script>
	const button = document.querySelector('#emailButton');
	const email = 'e.benjaminsalazarrubilar@gmail.com';
	button.addEventListener('click', () => {
		navigator.clipboard.writeText(email);
	});
</script>

