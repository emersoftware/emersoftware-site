---
import Layout from '../layouts/Layout.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import Mail from '../components/icons/MailIcon.astro';
import Copy from '../components/icons/CopyIcon.astro';
import CopyCheck from '../components/icons/CopyCheckIcon.astro';
import GitHubLatestCommit from '../components/GitHubLatestCommit.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import BlogList from '../components/BlogList.astro';
import Navbar from '../components/Navbar.astro';
import SectionNav from '../components/SectionNav.astro';
import Footer from '../components/Footer.astro';
import { getDictionary } from '../i18n/dictionaries';
import { defaultLocale } from '../i18n/config';

const lang = defaultLocale;
const t = getDictionary(lang);
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang} bare>
  <!-- El hero permanece fijo mientras la hoja lo cubre. h-lvh: cubre siempre la
       pantalla física completa (notch a home indicator) sin importar el estado
       de las barras de Safari — cero reflow al colapsarlas y el gradiente llega
       al borde real. El contenido se ancla a h-svh para no quedar tras la barra. -->
  <section class="hero-section fixed inset-0 z-0 h-lvh overflow-hidden">
    <div class="absolute inset-0">
      <picture>
        <source media="(min-width: 768px)" srcset="/hero-bg.jpeg" />
        <img
          src="/hero-bg-mobile.jpeg"
          alt=""
          class="h-full w-full object-cover object-bottom md:object-center"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>

    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black to-transparent lg:hidden"
      aria-hidden="true"
    >
    </div>

    <div data-hero-overlay class="relative h-svh">
      <Navbar lang={lang} />

      <div class="relative z-10 flex h-full items-end">
        <div class="w-full min-w-0 px-6 pb-36 md:px-12 md:pb-48 lg:px-16 lg:pb-32">
          <div class="w-full max-w-2xl min-w-0">
            <GitHubLatestCommit lang={lang} class="mb-4 flex w-full" />

            <div class="fade-in">
              <h1 data-hero-fade class="title text-lg text-white md:text-2xl lg:text-4xl">
                {t.hero.name}
              </h1>
            </div>

            <div class="fade-in-delay-100 mt-3">
              <p data-hero-fade class="text-lg text-white/80 md:text-xl lg:text-2xl">
                {t.hero.role}
              </p>
            </div>

            <div class="fade-in-delay-200 mt-6">
              <p data-hero-fade class="max-w-lg text-base break-words text-white/70 md:text-lg">
                {t.hero.about}
              </p>
            </div>

            <nav class="mt-4 flex min-w-0 justify-center gap-1 md:hidden">
              <a
                href="https://github.com/emersoftware"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <GitHubIcon class="size-4" />
                <span>github</span>
              </a>
              <a
                href="https://www.linkedin.com/in/emerson-salazar-rubilar"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <LinkedInIcon class="size-4" />
                <span>linkedin</span>
              </a>
              <button
                id="emailButtonMobile"
                class="hero-pill flex min-w-0 items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-2.5 py-2 text-xs text-white backdrop-blur-md hover:bg-white/20"
              >
                <Mail class="size-4" />
                <span>email</span>
                <Copy id="copyEmailMobile" class="size-4" />
                <CopyCheck id="copyEmailCheckMobile" class="hidden size-4" />
              </button>
            </nav>

            <nav class="mt-8 hidden flex-wrap gap-3 md:flex">
              <a
                href="https://github.com/emersoftware"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-sm text-white backdrop-blur-md hover:bg-white/20"
              >
                <GitHubIcon class="size-4" />
                <span>GitHub</span>
              </a>
              <a
                href="https://www.linkedin.com/in/emerson-salazar-rubilar"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-sm text-white backdrop-blur-md hover:bg-white/20"
              >
                <LinkedInIcon class="size-4" />
                <span>LinkedIn</span>
              </a>
              <button
                id="emailButtonDesktop"
                class="hero-pill flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-sm text-white backdrop-blur-md hover:bg-white/20"
              >
                <Mail class="size-4" />
                <span>{t.hero.email}</span>
                <Copy id="copyEmailDesktop" class="size-4" />
                <CopyCheck id="copyEmailCheckDesktop" class="hidden size-4" />
              </button>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Espaciador: la primera pantalla de scroll es la aproximación de la hoja.
       lvh (constante): con la barra de Safari expandida la hoja reposa bajo el
       viewport y su filo nunca asoma sobre la barra inferior. -->
  <div data-hero-spacer class="pointer-events-none h-lvh" aria-hidden="true"></div>

  <!-- La hoja vive en el flujo del documento: el desplazamiento es 100% nativo,
       ningún JavaScript traslada el contenido durante el scroll. -->
  <div data-sheet class="relative z-20 mx-auto w-full max-w-4xl px-3 md:max-w-5xl md:px-6">
    <div class="bg-white pb-[env(safe-area-inset-bottom,0px)] shadow-2xl">
      <SectionNav lang={lang} />

      <div class="px-6 py-16 md:px-12 md:py-20">
        <section id="experiencia" data-section="experiencia">
          <Experience lang={lang} />
        </section>

        <section id="proyectos" data-section="proyectos" class="mt-20 md:mt-28">
          <Projects lang={lang} />
        </section>

        <section id="blog" data-section="blog" class="mt-20 md:mt-28">
          <BlogList lang={lang} />
        </section>

        <section id="contacto" data-section="contacto" class="mt-20 md:mt-28">
          <Contact lang={lang} />
        </section>
      </div>

      <Footer lang={lang} currentPath={Astro.url.pathname} />
    </div>
  </div>

  <!-- Franja "peek": replica el hero en la banda superior para ocultar el
       contenido que pasa por encima del nav sticky. Solo se muestra dockeada
       la hoja; en reposo taparía la Navbar del hero. -->
  <!-- bg-black en el fixed mismo: es la fuente de tinte que Liquid Glass
       muestrea para el chrome superior cuando la hoja está dockeada. -->
  <div
    data-hero-peek
    class="pointer-events-none fixed inset-x-0 top-0 z-30 overflow-hidden bg-black"
    aria-hidden="true"
  >
    <div class="hero-peek-inner absolute top-0 left-0 h-lvh w-screen">
      <picture>
        <source media="(min-width: 768px)" srcset="/hero-bg.jpeg" />
        <img
          src="/hero-bg-mobile.jpeg"
          alt=""
          class="h-full w-full object-cover object-bottom md:object-center"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
  </div>
</Layout>

<style>
  :global(:root) {
    --sheet-top: 0.75rem;
  }

  @media (min-width: 48rem) {
    :global(:root) {
      --sheet-top: 1.5rem;
    }
  }

  @media (min-width: 64rem) {
    :global(:root) {
      --sheet-top: 4.5rem;
    }
  }

  /* Los anchors nativos deben aterrizar bajo la banda superior + nav sticky. */
  [data-section] {
    scroll-margin-top: calc(env(safe-area-inset-top, 0px) + var(--sheet-top) + 3.5rem);
  }

  /* La franja cubre también la zona de la status bar (safe-area): en Safari
     minimizado el documento pinta detrás del notch y hay que taparlo. */
  [data-hero-peek] {
    height: calc(env(safe-area-inset-top, 0px) + var(--sheet-top));
    display: none;
  }

  :global(html[data-docked]) [data-hero-peek] {
    display: block;
  }

  @supports not (height: 100lvh) {
    [data-hero-spacer] {
      height: 100vh;
    }

    .hero-peek-inner {
      height: 100vh;
    }
  }
</style>

<script define:vars={{ email: t.hero.email }}>
  function setupEmailButton(buttonId, copyId, checkId) {
    const button = document.querySelector(buttonId);
    const copyIcon = document.querySelector(copyId);
    const checkIcon = document.querySelector(checkId);

    if (button && copyIcon && checkIcon) {
      button.addEventListener('click', () => {
        navigator.clipboard.writeText(email).then(() => {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 2000);
        });
      });
    }
  }

  setupEmailButton('#emailButtonDesktop', '#copyEmailDesktop', '#copyEmailCheckDesktop');
  setupEmailButton('#emailButtonMobile', '#copyEmailMobile', '#copyEmailCheckMobile');
</script>

<script>
  import '../scripts/home-scroll';
</script>
