  <main class="mx-4 py-24 text-center md:mx-auto md:w-3/5 lg:w-1/2">
    <h1 class="title text-5xl lg:text-7xl">404</h1>
    <p class="mt-4 text-lg">La página que buscas no existe.</p>
    <nav class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="underline">Inicio</a>
      <a href="/#experiencia" class="underline">Experiencia</a>
      <a href="/#contacto" class="underline">Contacto</a>
    </nav>
  </main>
</Layout>
