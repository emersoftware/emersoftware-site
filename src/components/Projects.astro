---
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';

interface Props {
  lang?: string;
}

const { lang: rawLang = 'es' } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);
---

<h2 class="text-left text-lg text-black lg:text-2xl">{t.sectionHeadings.projects}</h2>
<ul class="mt-8 text-sm text-black">
  {
    t.projectItems.map((project) => (
      <li>
        <details class="group">
          <summary class="grid cursor-pointer list-none grid-cols-[minmax(0,1fr)_auto] items-start gap-x-3 gap-y-2 px-1 py-3 sm:items-baseline [&::-webkit-details-marker]:hidden">
            <span class="col-span-2 flex min-w-0 flex-wrap items-baseline gap-x-2 sm:col-span-1">
              <span>{project.title}</span>
              <span class="text-graphite-400">-</span>
              <span class="text-graphite-600">{project.summary}</span>
            </span>
            <span class="col-start-2 row-start-2 flex shrink-0 items-center gap-3 sm:row-start-1">
              {project.repo && (
                <a
                  href={project.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black underline-offset-2 transition-colors hover:text-orange-500 hover:underline"
                  onclick="event.stopPropagation()"
                >
                  [ {t.list.github} ]
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black underline-offset-2 transition-colors hover:text-orange-500 hover:underline"
                  onclick="event.stopPropagation()"
                >
                  [ {t.list.demo} ]
                </a>
              )}
              {project.link && !project.demo && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black underline-offset-2 transition-colors hover:text-orange-500 hover:underline"
                  onclick="event.stopPropagation()"
                >
                  [ {t.list.view} ]
                </a>
              )}
              <span class="text-graphite-500 shrink-0 group-open:hidden" aria-hidden="true">
                [ + ]
              </span>
              <span class="text-graphite-500 hidden shrink-0 group-open:inline" aria-hidden="true">
                [ - ]
              </span>
            </span>
          </summary>
          <div class="px-1 pb-4">
            <p class="text-graphite-600 max-w-3xl leading-relaxed">{project.description}</p>
          </div>
        </details>
      </li>
    ))
  }
</ul>
