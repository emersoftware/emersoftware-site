---
interface Props {
  success?: string;
  id?: string;
  class?: string;
}

const { success = 'false' } = Astro.props;
const isSuccess = success === 'true';
---

<span
  class={`
        items-center
        mt-4
        py-4
        px-8
        rounded-xl
        border
        transition
        flex
        hidden
        fade-in
        ${
          isSuccess
            ? 'text-white bg-orange-500 border-orange-500'
            : 'text-white bg-red border-red justify-center'
        }
    `}
  {...Astro.props}
>
  <slot />
</span>
