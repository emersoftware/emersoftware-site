---
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';

interface Props {
  lang?: string;
}

const { lang: rawLang = defaultLocale } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);

const sectionHref = (id: string) => (lang === 'en' ? `/en/#${id}` : `/#${id}`);

const navItems = [
  { id: t.sectionIds.experience, label: t.navbar.experience },
  { id: t.sectionIds.projects, label: t.navbar.projects },
  { id: 'blog', label: t.navbar.blog },
  { id: t.sectionIds.contact, label: t.navbar.contact },
];
---

<nav
  id="navbar"
  class="navbar-hero relative z-20 pt-[env(safe-area-inset-top,0px)] transition-opacity duration-300"
  data-hero-ui
  data-hero-fade
>
  <div class="mx-auto flex items-center justify-center px-4 py-4 md:px-12 lg:px-16">
    <ul
      class="absolute top-[calc(env(safe-area-inset-top,0px)+1rem)] left-1/2 flex -translate-x-1/2 flex-row items-center gap-4 text-xs whitespace-nowrap md:static md:translate-x-0 md:gap-6 md:text-sm"
    >
      {
        navItems.map((item) => (
          <li>
            <a
              href={sectionHref(item.id)}
              class="nav-link text-white/80 transition-colors hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .nav-link {
    position: relative;
    padding-bottom: 2px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background-color: currentColor;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
