---
import Alert from '../components/Alert.astro'
---
<Alert id="alertSuccessEmail" success="true">
    Gracias por tu mensaje! Te responderé lo antes posible.
</Alert>
<Alert id="alertErrorEmail">
    Hubo un error al enviar tu mensaje, por favor intenta de nuevo o contactame por otro medio
</Alert>
<form
    method="POST"
    class="
        bg-white dark:bg-black
        rounded-lg lg:rounded-xl
        border-2 border-black dark:border-white
        pt-6 lg:pt-10
        pb-4 lg:pb-8
        px-8 lg:px-12
        mt-4 lg:mt-8   
        flex flex-col
        lg:text-xl
        w-full
        mb-16"
    
>
    <h3 class="text-left text-lg lg:text-2xl">Envíame un mensaje</h3>
    <label class="mt-2 lg:mt-8" 
        for="firstname"
    >Nombre</label>
    <input 
        class="border-b w-1/2 bg-white dark:bg-black" 
        type="text" 
        name="firstname"
        id="firstname"
        placeholder="Ingresa tu nombre"
        required
    />
    <label 
        class="mt-2 lg:mt-8"
        for="lastname"
    >Apellido</label>
    <input
        class="border-b w-1/2 bg-white dark:bg-black"
        type="text"
        name="lastname"
        id="lastname"
        placeholder="Ingresa tu apellido"
        required
    />
    <label
        class="mt-2 lg:mt-8"
        for="email"
    >Email</label>
    <input
        class="border-b w-1/2 bg-white dark:bg-black"
        type="email"
        name="email"
        id="email"
        placeholder="Ingresa tu email"
        required
    />
    <label
        class="mt-2 lg:mt-8"
        for="message"
    >Mensaje</label>
    <textarea 
        class="border-2 h-16 rounded-lg mt-2 p-2 bg-white dark:bg-black"
        name="message"
        id="message"
        cols="30"
        rows="10"
        required
    > 
    </textarea>
    <button 
        class="self-center mt-4 py-1 w-1/2 lg:w-1/3 lg:mt-6
            bg-tangerine dark:bg-mint
            hover:dark:bg-mint/90 hover:bg-tangerine/90
            text-white dark:text-black text-lg lg:text-2xl
            rounded-full" 
        type="submit"
    >
        Enviar
    </button>
</form>

<script>
    const form = document.querySelector('form');
    const alertSuccess = document.querySelector('#alertSuccessEmail');
    const alertError = document.querySelector('#alertErrorEmail');
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        
        const res = await fetch('/email', {
            method: 'POST',
            body: formData,
        });
        
        if (res.ok) {
            alertSuccess.classList.remove('hidden');
            form.reset();
            setTimeout(() => {
                alertSuccess.classList.add('hidden');
            }, 10000);
        } else {
            alertError.classList.remove('hidden');
            setTimeout(() => {
                alertError.classList.add('hidden');
            }, 10000);
        }
    })