---
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';
import { GITHUB_TOKEN } from 'astro:env/server';

interface Props {
  lang?: string;
  class?: string;
}

interface CommitData {
  repo: string;
  message: string;
  sha: string;
  date: Date;
  url: string;
}

const { lang: rawLang = 'es', class: className = '' } = Astro.props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);

let commit: CommitData | null = null;

try {
  // `caches.default` solo existe en el runtime de Cloudflare Workers.
  // En `astro dev` (Node) no está disponible, así que hacemos el fetch directo.
  const cache =
    typeof caches !== 'undefined' && 'default' in caches
      ? (caches as CacheStorage & { default: Cache }).default
      : null;
  const cacheKey = new Request('https://emersoftware.cl/.cache/github/latest-public-commit');
  let response = cache ? await cache.match(cacheKey) : undefined;

  if (!response) {
    const headers = new Headers({
      Accept: 'application/vnd.github+json',
      'User-Agent': 'emersoftware-site',
      'X-GitHub-Api-Version': '2022-11-28',
    });

    if (GITHUB_TOKEN) {
      headers.set('Authorization', `Bearer ${GITHUB_TOKEN}`);
    }

    const githubResponse = await fetch(
      'https://api.github.com/search/commits?q=author:emersoftware&sort=author-date&order=desc&per_page=1',
      {
        headers,
        signal: AbortSignal.timeout(5000),
      }
    );

    if (!githubResponse.ok) {
      console.error('GitHub API error:', {
        status: githubResponse.status,
        rateLimitRemaining: githubResponse.headers.get('x-ratelimit-remaining'),
      });
    } else {
      response = new Response(await githubResponse.text(), {
        headers: {
          'Content-Type': 'application/json',
          'Cache-Control': 'public, max-age=300',
        },
      });
      if (cache) {
        await cache.put(cacheKey, response.clone());
      }
    }
  }

  if (response?.ok) {
    const data = await response.json();
    if (data.items && data.items.length > 0) {
      const c = data.items[0];
      const message = c.commit.message.split('\n')[0];
      commit = {
        repo: c.repository.name,
        message: message,
        sha: c.sha.substring(0, 7),
        date: new Date(c.commit.author.date),
        url: c.html_url,
      };
    }
  }
} catch (e) {
  console.error('GitHub API error:', e);
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');

function getRelativeTime(date: Date): string {
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  const diffWeeks = Math.floor(diffDays / 7);
  const diffMonths = Math.floor(diffDays / 30);

  const translations = t.githubCommit.timeAgo;

  if (diffMins < 1) return translations.justNow;
  if (diffMins < 60) return translations.minutesAgo.replace('{n}', String(diffMins));
  if (diffHours < 24) return translations.hoursAgo.replace('{n}', String(diffHours));
  if (diffDays < 7) return translations.daysAgo.replace('{n}', String(diffDays));
  if (diffWeeks < 4) return translations.weeksAgo.replace('{n}', String(diffWeeks));
  return translations.monthsAgo.replace('{n}', String(diffMonths));
}

const relativeTime = commit ? getRelativeTime(commit.date) : '';
---

{
  commit ? (
    <a
      href={commit.url}
      target="_blank"
      rel="noopener noreferrer"
      class={`hero-pill flex max-w-full min-w-0 items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-sm text-white backdrop-blur-md hover:bg-white/20 ${className}`}
    >
      <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
      </svg>
      <span class="max-w-[35%] shrink-0 truncate font-medium sm:max-w-none">{commit.repo}</span>
      <code class="hidden shrink-0 rounded bg-white/20 px-1.5 py-0.5 font-mono text-xs md:inline">
        {commit.sha}
      </code>
      <span class="min-w-0 flex-1 truncate text-white/70">{commit.message}</span>
      <span class="shrink-0 whitespace-nowrap text-white/50">{relativeTime}</span>
    </a>
  ) : null
}
