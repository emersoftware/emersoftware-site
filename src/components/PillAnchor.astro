---
interface Props {
  href: string;
  class?: string;
}
---

<a
  class={`
    dark:bg-black bg-forest
    border border-white rounded-full
    flex flex-1 justify-center items-center gap-x-2
    py-1 px-4 md:py-2 md:px-4 lg:py-2 lg:px-6
    text-md lg:text-2xl
    text-white
    hover:text-tangerine hover:border-tangerine
    hover:dark:text-mint hover:dark:border-mint
    transition
  `}
  {...Astro.props}
  target="_blank"
  rel="noopener noreferrer"
>
  <slot />
</a>
