---
interface Props {
  href: string;
  class?: string;
}
---

<a
  class={`
    bg-graphite-700
    border border-graphite-600 rounded-full
    flex flex-1 justify-center items-center gap-x-2
    py-1 px-4 md:py-2 md:px-4 lg:py-2 lg:px-6
    text-md lg:text-2xl
    text-white
    hover:bg-orange-500 hover:border-orange-500 hover:text-white
    transition
  `}
  {...Astro.props}
  target="_blank"
  rel="noopener noreferrer"
>
  <slot />
</a>
