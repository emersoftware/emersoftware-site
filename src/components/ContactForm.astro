---
// ContactForm component to handle the contact form functionality
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';
interface Props {
  lang?: string;
}
const { lang: rawLang = 'es' } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);

const TURNSTILE_IS_LOCALHOST =
  Astro.url.hostname === 'localhost' ||
  Astro.url.hostname === '127.0.0.1' ||
  Astro.url.hostname === '0.0.0.0' ||
  Astro.url.hostname.startsWith('192.168.') ||
  Astro.url.hostname.startsWith('10.');

const TURNSTILE_SITE_KEY =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
  (TURNSTILE_IS_LOCALHOST ? '1x00000000000000000000AA' : undefined);
---

<form id="contact-form" method="POST" class="mt-8 flex w-full flex-col lg:text-lg">
  <h3 class="text-left text-lg text-black lg:text-2xl">{t.contact.form.sendMeAMessage}</h3>
  <div class="flex">
    <div class="hidden w-1/2 items-center justify-start md:flex">
      <img src="/cats.jpeg" alt="" class="w-80 lg:w-96" loading="lazy" decoding="async" />
    </div>
    <div class="w-full md:w-1/2">
      <label class="fade-in-delay-100 text-graphite-700 mt-4 block lg:mt-8" for="firstname"
        >{t.contact.form.firstnameLabel}</label
      >
      <input
        class="fade-in-delay-100 border-graphite-300 placeholder-graphite-400 w-full border-b bg-white py-2 text-black focus:border-orange-500 focus:outline-none"
        type="text"
        name="firstname"
        id="firstname"
        placeholder={t.contact.form.firstnamePlaceholder}
        required
      />
      <label class="fade-in-delay-200 text-graphite-700 mt-4 block lg:mt-8" for="lastname"
        >{t.contact.form.lastnameLabel}</label
      >
      <input
        class="fade-in-delay-200 border-graphite-300 placeholder-graphite-400 w-full border-b bg-white py-2 text-black focus:border-orange-500 focus:outline-none"
        type="text"
        name="lastname"
        id="lastname"
        placeholder={t.contact.form.lastnamePlaceholder}
        required
      />
      <label class="fade-in-delay-300 text-graphite-700 mt-4 block lg:mt-8" for="email"
        >{t.contact.form.emailLabel}</label
      >
      <input
        class="fade-in-delay-300 border-graphite-300 placeholder-graphite-400 w-full border-b bg-white py-2 text-black focus:border-orange-500 focus:outline-none"
        type="email"
        name="email"
        id="email"
        placeholder={t.contact.form.emailPlaceholder}
        required
      />
      <label class="fade-in-delay-400 text-graphite-700 mt-4 block lg:mt-8" for="message"
        >{t.contact.form.messageLabel}</label
      >
      <textarea
        class="fade-in-delay-400 border-graphite-300 placeholder-graphite-400 mt-2 h-24 w-full rounded-lg border bg-white p-3 text-black focus:border-orange-500 focus:outline-none"
        name="message"
        id="message"
        cols="30"
        rows="10"
        required></textarea>
      <div class="fade-in-delay-500 mt-6 flex justify-center md:justify-start">
        {TURNSTILE_SITE_KEY && (
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} />
        )}
      </div>
      <button
        class="fade-in-delay-500 mt-6 w-full rounded-full bg-orange-400 py-2.5 text-base font-medium text-white transition-colors hover:bg-orange-500 lg:text-lg"
        type="submit"
        disabled={!TURNSTILE_SITE_KEY}
      >
        {t.contact.form.submit}
      </button>
    </div>
  </div>

  <!-- Gatos - Mobile only -->
  <div class="mt-8 flex justify-center md:hidden">
    <img src="/cats.jpeg" alt="" class="w-64" loading="lazy" decoding="async" />
  </div>
</form>

{
  TURNSTILE_SITE_KEY && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
  )
}

<script is:inline>
  const form = document.querySelector('#contact-form');
  const alertSuccess = document.querySelector('#alertSuccessEmail');
  const alertError = document.querySelector('#alertErrorEmail');

  const submitBtn = form.querySelector('button[type="submit"]');
  const submitLabel = submitBtn ? submitBtn.textContent : '';

  const showAlert = (el) => {
    el.classList.remove('hidden');
    clearTimeout(el._hideTimer);
    el._hideTimer = setTimeout(() => el.classList.add('hidden'), 10000);
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn?.disabled) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-60', 'cursor-not-allowed');
      submitBtn.textContent = '...';
    }

    try {
      const res = await fetch('/email', {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        showAlert(alertSuccess);
        form.reset();
        window.turnstile?.reset();
      } else {
        showAlert(alertError);
      }
    } catch (_) {
      showAlert(alertError);
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-60', 'cursor-not-allowed');
        submitBtn.textContent = submitLabel;
      }
    }
  });
</script>
