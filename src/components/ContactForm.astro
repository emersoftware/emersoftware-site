---
// ContactForm component to handle the contact form functionality
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';
interface Props {
  lang?: string;
}
const { lang: rawLang = 'es' } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);
const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY || 'YOUR_SITE_KEY';
---

<form
  method="POST"
  class="mb-16 mt-4 flex w-full flex-col rounded-lg border-2 border-black bg-white px-8 pb-4 pt-6 lg:mt-8 lg:rounded-xl lg:px-12 lg:pb-8 lg:pt-10 lg:text-xl dark:border-white dark:bg-black"
>
  <h3 class="text-left text-lg lg:text-2xl">{t.contact.form.sendMeAMessage}</h3>
  <label class="fade-in-delay-100 mt-2 lg:mt-8" for="firstname"
    >{t.contact.form.firstnameLabel}</label
  >
  <input
    class="fade-in-delay-100 w-1/2 border-b bg-white dark:bg-black"
    type="text"
    name="firstname"
    id="firstname"
    placeholder={t.contact.form.firstnamePlaceholder}
    required
  />
  <label class="fade-in-delay-200 mt-2 lg:mt-8" for="lastname">{t.contact.form.lastnameLabel}</label
  >
  <input
    class="fade-in-delay-200 w-1/2 border-b bg-white dark:bg-black"
    type="text"
    name="lastname"
    id="lastname"
    placeholder={t.contact.form.lastnamePlaceholder}
    required
  />
  <label class="fade-in-delay-300 mt-2 lg:mt-8" for="email">{t.contact.form.emailLabel}</label>
  <input
    class="fade-in-delay-300 w-1/2 border-b bg-white dark:bg-black"
    type="email"
    name="email"
    id="email"
    placeholder={t.contact.form.emailPlaceholder}
    required
  />
  <label class="fade-in-delay-400 mt-2 lg:mt-8" for="message">{t.contact.form.messageLabel}</label>
  <textarea
    class="fade-in-delay-400 mt-2 h-16 rounded-lg border-2 bg-white p-2 dark:bg-black"
    name="message"
    id="message"
    cols="30"
    rows="10"
    required
  >
  </textarea>

  <div class="fade-in-delay-500 mt-4 flex justify-center">
    <div id="cf-turnstile"></div>
  </div>

  <button
    class="fade-in-delay-500 mt-4 w-1/2 self-center rounded-full bg-tangerine py-1 text-lg text-white hover:bg-tangerine/90 lg:mt-6 lg:w-1/3 lg:text-2xl dark:bg-mint dark:text-black hover:dark:bg-mint/90"
    type="submit"
  >
    {t.contact.form.submit}
  </button>
</form>

<script define:vars={{ siteKey: TURNSTILE_SITE_KEY }}>
  const form = document.querySelector('form');
  const alertSuccess = document.querySelector('#alertSuccessEmail');
  const alertError = document.querySelector('#alertErrorEmail');

  window.onloadTurnstileCallback = function () {
    window.turnstile.render('#cf-turnstile', {
      sitekey: siteKey,
      callback: function (token) {
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = 'cf-turnstile-response';
        tokenInput.value = token;
        form.appendChild(tokenInput);
      },
    });
  };

  const script = document.createElement('script');
  script.src =
    'https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onloadTurnstileCallback';
  script.async = true;
  script.defer = true;
  document.head.appendChild(script);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    const res = await fetch('/email', {
      method: 'POST',
      body: formData,
    });

    if (res.ok) {
      alertSuccess.classList.remove('hidden');
      form.reset();
      // Reset Turnstile after successful submission
      if (window.turnstile) {
        window.turnstile.reset();
      }
      setTimeout(() => {
        alertSuccess.classList.add('hidden');
      }, 10000);
    } else {
      alertError.classList.remove('hidden');
      setTimeout(() => {
        alertError.classList.add('hidden');
      }, 10000);
    }
  });
</script>
