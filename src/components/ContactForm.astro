---
// ContactForm component to handle the contact form functionality
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';
interface Props {
  lang?: string;
}
const { lang: rawLang = 'es' } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);

const TURNSTILE_IS_LOCALHOST =
  Astro.url.hostname === 'localhost' ||
  Astro.url.hostname === '127.0.0.1' ||
  Astro.url.hostname === '0.0.0.0' ||
  Astro.url.hostname.startsWith('192.168.') ||
  Astro.url.hostname.startsWith('10.');

const TURNSTILE_SITE_KEY =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
  (TURNSTILE_IS_LOCALHOST ? '1x00000000000000000000AA' : undefined);
---

<form id="contact-form" method="POST" class="mt-8 flex w-full flex-col lg:text-lg">
  <h3 class="text-center text-lg text-black lg:text-2xl">{t.contact.form.sendMeAMessage}</h3>
  <div class="flex">
    <div class="hidden w-1/2 items-center justify-start md:flex">
      <img src="/cats.jpeg" alt="" class="w-80 lg:w-96" loading="lazy" decoding="async" />
    </div>
    <div class="w-full pt-8 md:w-1/2 md:pt-10 lg:pt-12">
      <label class="fade-in-delay-100 text-graphite-700 block" for="email"
        >{t.contact.form.emailLabel}</label
      >
      <input
        class="contact-serif fade-in-delay-100 border-graphite-300 placeholder-graphite-400 w-full border-b bg-white py-2 font-serif text-black placeholder:font-serif focus:border-orange-500 focus:outline-none"
        type="email"
        name="email"
        id="email"
        placeholder={t.contact.form.emailPlaceholder}
        required
      />
      <label class="fade-in-delay-200 text-graphite-700 mt-4 block lg:mt-8" for="message"
        >{t.contact.form.messageLabel}</label
      >
      <textarea
        class="contact-serif notebook-textarea fade-in-delay-200 placeholder-graphite-400 mt-2 h-40 w-full resize-none rounded-none border-0 px-1 font-serif text-black placeholder:font-serif focus:outline-none"
        name="message"
        id="message"
        cols="30"
        rows="10"
        placeholder={t.contact.form.messagePlaceholder}
        required></textarea>
      <div class="fade-in-delay-500 mt-6 min-h-[65px]">
        <!-- Render explícito y diferido: sin la clase cf-turnstile no hay
             auto-render; el script se inyecta al acercarse el formulario. -->
        <div class="flex justify-center md:justify-start">
          {TURNSTILE_SITE_KEY && <div data-turnstile-slot data-sitekey={TURNSTILE_SITE_KEY} />}
        </div>
        <p data-turnstile-status class="text-red mt-2 hidden text-center text-sm md:text-left">
          {t.contact.form.verificationFailed}
          <button type="button" data-turnstile-retry class="cursor-pointer underline">
            {t.contact.form.retry}
          </button>
        </p>
      </div>
      <div class="mt-6 flex justify-end">
        <button
          class="contact-serif fade-in-delay-500 inline-flex w-fit shrink-0 items-center justify-center rounded-none border-0 bg-orange-400 px-6 py-2.5 font-serif text-base font-normal text-white transition-colors hover:bg-orange-500 focus:outline-2 focus:outline-offset-2 focus:outline-orange-500 disabled:cursor-not-allowed disabled:opacity-60 lg:text-lg"
          type="submit"
          disabled
        >
          {t.contact.form.submit}
        </button>
      </div>
    </div>
  </div>

  <!-- Gatos - Mobile only -->
  <div class="mt-8 flex justify-center md:hidden">
    <img src="/cats.jpeg" alt="" class="w-64" loading="lazy" decoding="async" />
  </div>
</form>

<style is:global>
  #contact-form .contact-serif,
  #contact-form .contact-serif::placeholder {
    font-family: 'Jacques Francois', serif !important;
    font-weight: 400 !important;
  }

  #contact-form .notebook-textarea {
    line-height: 2.25rem;
    padding-top: 0;
    padding-bottom: 0;
    caret-color: var(--color-orange-500);
    background-color: transparent;
    background-image: linear-gradient(
      to bottom,
      transparent calc(2.25rem - 1px),
      var(--color-graphite-300) calc(2.25rem - 1px)
    );
    background-size: 100% 2.25rem;
    background-attachment: local;
  }
</style>

<script is:inline>
  (() => {
    const form = document.querySelector('#contact-form');
    if (!form) return;

    const alertSuccess = document.querySelector('#alertSuccessEmail');
    const alertError = document.querySelector('#alertErrorEmail');
    const submitBtn = form.querySelector('button[type="submit"]');
    const submitLabel = submitBtn ? submitBtn.textContent : '';
    const slot = form.querySelector('[data-turnstile-slot]');
    const statusEl = form.querySelector('[data-turnstile-status]');
    const retryBtn = form.querySelector('[data-turnstile-retry]');

    let widgetId = null;
    let scriptEl = null;

    const setSubmitEnabled = (enabled) => {
      if (submitBtn) submitBtn.disabled = !enabled;
    };

    const showStatus = (visible) => {
      statusEl?.classList.toggle('hidden', !visible);
    };

    const showAlert = (el) => {
      if (!el) return;
      el.classList.remove('hidden');
      clearTimeout(el._hideTimer);
      el._hideTimer = setTimeout(() => el.classList.add('hidden'), 10000);
    };

    // --- Turnstile diferido con render explícito -------------------------
    // El script no se descarga en la carga inicial del home: se inyecta al
    // acercarse el formulario (o al enfocarlo). El botón solo se habilita
    // cuando el widget entrega un token; el server sigue validando siempre.

    const renderWidget = () => {
      if (!slot || widgetId !== null || !window.turnstile) return;
      try {
        widgetId = window.turnstile.render(slot, {
          sitekey: slot.dataset.sitekey,
          callback: () => {
            showStatus(false);
            setSubmitEnabled(true);
          },
          'expired-callback': () => setSubmitEnabled(false),
          'error-callback': () => {
            setSubmitEnabled(false);
            showStatus(true);
          },
          'timeout-callback': () => setSubmitEnabled(false),
        });
      } catch (_) {
        showStatus(true);
      }
    };

    window.__onTurnstileLoad = renderWidget;

    const loadTurnstile = () => {
      if (!slot) return;
      if (window.turnstile) {
        renderWidget();
        return;
      }
      if (scriptEl) return;
      showStatus(false);
      scriptEl = document.createElement('script');
      scriptEl.src =
        'https://challenges.cloudflare.com/turnstile/v0/api.js?onload=__onTurnstileLoad&render=explicit';
      scriptEl.async = true;
      scriptEl.onerror = () => {
        scriptEl?.remove();
        scriptEl = null;
        setSubmitEnabled(false);
        showStatus(true);
      };
      document.head.appendChild(scriptEl);
    };

    retryBtn?.addEventListener('click', loadTurnstile);

    if (slot) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              io.disconnect();
              loadTurnstile();
            }
          },
          { rootMargin: '800px 0px' }
        );
        io.observe(form);
        // Por si el usuario llega por teclado o autofocus antes del umbral.
        form.addEventListener('focusin', () => {
          io.disconnect();
          loadTurnstile();
        });
      } else {
        loadTurnstile();
      }
    }

    // --- Envío ------------------------------------------------------------

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn?.disabled) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = '...';
      }

      try {
        const res = await fetch('/email', {
          method: 'POST',
          body: new FormData(form),
        });

        if (res.ok) {
          showAlert(alertSuccess);
          form.reset();
        } else {
          showAlert(alertError);
        }
      } catch (_) {
        showAlert(alertError);
      } finally {
        if (submitBtn) submitBtn.textContent = submitLabel;
        // El token es de un solo uso: tras cualquier intento se renueva y el
        // botón queda deshabilitado hasta que llegue el token nuevo.
        if (widgetId !== null && window.turnstile) {
          setSubmitEnabled(false);
          window.turnstile.reset(widgetId);
        } else {
          setSubmitEnabled(false);
        }
      }
    });
  })();
</script>
