---
// ContactForm component to handle the contact form functionality
import { getDictionary } from '../i18n/dictionaries';
import { isSupportedLocale, defaultLocale } from '../i18n/config';
interface Props {
  lang?: string;
}
const { lang: rawLang = 'es' } = Astro.props as Props;
const lang = isSupportedLocale(rawLang) ? rawLang : defaultLocale;
const t = getDictionary(lang);
const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY || 'YOUR_SITE_KEY';
---

<form
  method="POST"
  class="mt-8 flex w-full flex-col lg:text-lg"
>
  <h3 class="text-left text-lg text-black lg:text-2xl">{t.contact.form.sendMeAMessage}</h3>
  <div class="flex">
    <div class="hidden w-1/2 items-center justify-start md:flex">
      <img
        src="/cats.jpeg"
        alt=""
        class="w-80 lg:w-96"
        loading="lazy"
      />
    </div>
    <div class="w-full md:w-1/2">
      <label class="fade-in-delay-100 mt-4 block text-graphite-700 lg:mt-8" for="firstname"
        >{t.contact.form.firstnameLabel}</label
      >
      <input
        class="fade-in-delay-100 w-full border-b border-graphite-300 bg-white py-2 text-black placeholder-graphite-400 focus:border-orange-500 focus:outline-none"
        type="text"
        name="firstname"
        id="firstname"
        placeholder={t.contact.form.firstnamePlaceholder}
        required
      />
      <label class="fade-in-delay-200 mt-4 block text-graphite-700 lg:mt-8" for="lastname">{t.contact.form.lastnameLabel}</label
      >
      <input
        class="fade-in-delay-200 w-full border-b border-graphite-300 bg-white py-2 text-black placeholder-graphite-400 focus:border-orange-500 focus:outline-none"
        type="text"
        name="lastname"
        id="lastname"
        placeholder={t.contact.form.lastnamePlaceholder}
        required
      />
      <label class="fade-in-delay-300 mt-4 block text-graphite-700 lg:mt-8" for="email">{t.contact.form.emailLabel}</label>
      <input
        class="fade-in-delay-300 w-full border-b border-graphite-300 bg-white py-2 text-black placeholder-graphite-400 focus:border-orange-500 focus:outline-none"
        type="email"
        name="email"
        id="email"
        placeholder={t.contact.form.emailPlaceholder}
        required
      />
      <label class="fade-in-delay-400 mt-4 block text-graphite-700 lg:mt-8" for="message">{t.contact.form.messageLabel}</label>
      <textarea
        class="fade-in-delay-400 mt-2 h-24 w-full rounded-lg border border-graphite-300 bg-white p-3 text-black placeholder-graphite-400 focus:border-orange-500 focus:outline-none"
        name="message"
        id="message"
        cols="30"
        rows="10"
        required
      ></textarea>
      <div class="fade-in-delay-500 mt-6 flex justify-center md:justify-start">
        <div id="cf-turnstile"></div>
      </div>
      <button
        class="fade-in-delay-500 mt-6 w-full rounded-full bg-orange-400 py-2.5 text-base font-medium text-white transition-colors hover:bg-orange-500 lg:text-lg"
        type="submit"
      >
        {t.contact.form.submit}
      </button>
    </div>
  </div>

  <!-- Gatos - Mobile only -->
  <div class="mt-8 flex justify-center md:hidden">
    <img
      src="/cats.jpeg"
      alt=""
      class="w-64"
      loading="lazy"
    />
  </div>
</form>

<script define:vars={{ siteKey: TURNSTILE_SITE_KEY }}>
  const form = document.querySelector('form');
  const alertSuccess = document.querySelector('#alertSuccessEmail');
  const alertError = document.querySelector('#alertErrorEmail');

  window.onloadTurnstileCallback = function () {
    window.turnstile.render('#cf-turnstile', {
      sitekey: siteKey,
      callback: function (token) {
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = 'cf-turnstile-response';
        tokenInput.value = token;
        form.appendChild(tokenInput);
      },
    });
  };

  const script = document.createElement('script');
  script.src =
    'https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onloadTurnstileCallback';
  script.async = true;
  script.defer = true;
  document.head.appendChild(script);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    const res = await fetch('/email', {
      method: 'POST',
      body: formData,
    });

    if (res.ok) {
      alertSuccess.classList.remove('hidden');
      form.reset();
      // Reset Turnstile after successful submission
      if (window.turnstile) {
        window.turnstile.reset();
      }
      setTimeout(() => {
        alertSuccess.classList.add('hidden');
      }, 10000);
    } else {
      alertError.classList.remove('hidden');
      setTimeout(() => {
        alertError.classList.add('hidden');
      }, 10000);
    }
  });
</script>
