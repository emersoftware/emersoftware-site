---

interface Props {
  title: string
  description: string
  link?: string
  date: string
}

const { title, description, link, date } = Astro.props

---

<div
  class="absolute w-8 h-0 mt-2.5 -start-4 border border-black dark:border-white"
>
</div>
<h3 class="text-xl mt-2 ml-4">
  {title}
</h3>
<time
  class="mt-4 text-sm leading-none ml-4"
  >{date}</time
>
<p class="mt-4 text-pretty ml-4">
  {description}
</p>
<ul class="mt-2 ml-4 flex flex-row flex-wrap gap-2">
    <slot />
</ul>