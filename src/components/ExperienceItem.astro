---
interface Props {
  company: string;
  date: string;
  product: string;
  description: string;
  link?: string;
  viewLabel?: string;
}

const { company, date, product, description, link, viewLabel = 'ir a verlo' } = Astro.props;
---

<li>
  <details class="group">
    <summary
      class="flex cursor-pointer list-none flex-wrap items-baseline gap-2 px-1 py-3 [&::-webkit-details-marker]:hidden"
    >
      <span>{company}</span>
      <span class="text-graphite-400">-</span>
      <span>{product}</span>
      <span class="text-graphite-400">-</span>
      <span>{date}</span>
      {
        link && (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto shrink-0 text-black underline-offset-2 hover:text-orange-500 hover:underline"
            onclick="event.stopPropagation()"
          >
            [ {viewLabel} ]
          </a>
        )
      }
      <span class="text-graphite-500 shrink-0 group-open:hidden" aria-hidden="true">[ + ]</span>
      <span class="text-graphite-500 hidden shrink-0 group-open:inline" aria-hidden="true"
        >[ - ]</span
      >
    </summary>
    <div class="px-1 pb-4">
      <p class="text-graphite-600 max-w-3xl text-sm leading-relaxed">{description}</p>
    </div>
  </details>
</li>
