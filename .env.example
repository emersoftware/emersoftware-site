# Resend API Key for sending emails
RESEND_API_KEY=your_resend_api_key_here

# Cloudflare Turnstile Keys
# Get these from your Cloudflare dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# Public build-time site key (baked into the client bundle at build).
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Optional: raises the GitHub API rate limit for the latest-commit pill
GITHUB_TOKEN=your_read_only_github_token_here

# Keystatic CMS Security
# MUST be set to "true" in production builds to disable the Keystatic admin interface
# Leaving this unset or set to "false" will expose the unauthenticated CMS in production
SKIP_KEYSTATIC=true
